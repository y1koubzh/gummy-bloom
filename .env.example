# نسخ هذا الملف إلى `.env` ثم عدّل القيم عند الحاجة.
# Local MySQL (Docker): شغّل `corepack pnpm run docker:up` ثم `corepack pnpm run setup:local`

NODE_ENV=development
PORT=3000
# إذا أردت أن يفشل التشغيل عندما يكون المنفذ مشغولاً بدل الانتقال لمنفذ آخر:
# PORT_STRICT=true

# JWT للجلسات (لا تستخدم هذا السر في الإنتاج)
JWT_SECRET=gummy-bloom-local-dev-secret-min-32-chars-long-change-me

VITE_APP_ID=local-dev
VITE_OAUTH_PORTAL_URL=http://127.0.0.1:9
OAUTH_SERVER_URL=http://127.0.0.1:9
OWNER_OPEN_ID=

# قاعدة البيانات — المنفذ 3307 يطابق docker-compose.yml (فعّل بعد `docker:up`)
# DATABASE_URL=mysql://gummy:gummy_pass@127.0.0.1:3307/gummy_bloom

# Forge / ميزات اختيارية (اتركها فارغة إن لم تكن متوفرة)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
